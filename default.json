{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabled": true,
  "timezone": "Europe/Paris",
  "automerge": false,
  "prHourlyLimit": 10,
  "prConcurrentLimit": 5,
  "ignorePaths": [".build/**", "**/node_modules/**", "**/Pods/**"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability", "high-priority"],
    "prBodyNotes": [
      "**Severity:** {{{vulnerabilitySeverity}}}",
      "**CVEs:** {{{cveUrls}}}"
    ]
  },
  "enabledManagers": [
    "cocoapods",
    "swift",
    "gradle",
    "gradle-wrapper",
    "npm",
    "bundler",
    "pip_requirements"
  ],
  "packageRules": [
    {
      "description": "Group iOS dependency updates",
      "matchManagers": ["cocoapods"],
      "groupName": "iOS CocoaPods dependencies",
      "labels": ["dependencies", "automated", "ios", "cocoapods"]
    },
    {
      "description": "Group iOS Swift Package Manager dependency updates",
      "matchManagers": ["swift"],
      "groupName": "iOS Swift Package Manager dependencies",
      "labels": ["dependencies", "automated", "ios", "spm"]
    },
    {
      "description": "Group Android Gradle dependency updates",
      "matchManagers": ["gradle", "gradle-wrapper"],
      "groupName": "Android Gradle dependencies",
      "labels": ["dependencies", "automated", "android", "gradle"]
    },
    {
      "description": "Group Web npm dependency updates",
      "matchManagers": ["npm"],
      "groupName": "Web npm dependencies",
      "labels": ["dependencies", "automated", "web", "npm"]
    },
    {
      "description": "Group Web Ruby/Rails dependency updates",
      "matchManagers": ["bundler"],
      "groupName": "Web Ruby dependencies",
      "labels": ["dependencies", "automated", "web", "ruby", "bundler"]
    },
    {
      "description": "Group Python pip dependency updates",
      "matchManagers": ["pip_requirements"],
      "groupName": "Python pip dependencies",
      "labels": ["dependencies", "automated", "python", "pip"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "labels": ["patch-update"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "labels": ["dev-dependencies"],
      "automerge": false
    }
  ],
  "commitMessagePrefix": "chore:",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}{{#if hasVulnerabilityAlert}} (security){{/if}}"
}
